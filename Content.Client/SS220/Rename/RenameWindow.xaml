<DefaultWindow xmlns="https://spacestation14.io"
               Title="Смена имени"
               MinSize="300 300">
    <BoxContainer Orientation="Vertical"
                  HorizontalExpand="True"
                  VerticalExpand="True"
                  Margin="10 10 10 10">
        <Label Text="Выберите свое новое имя"
               Align="Center" />
        <Label Text="{Loc 'test-lalalala'}"
               Align="Center"
               FontColorOverride="Gray" />
        <BoxContainer MinHeight="20"></BoxContainer>
        <LineEdit Name="NameInput" />
        <BoxContainer MinHeight="20"></BoxContainer>
        <Button Name="ConfirmButton"
                Text="Подтвердить"
                StyleClasses="OpenBoth"
                MaxWidth="120"
                HorizontalAlignment="Center"
                VerticalExpand="False">
        </Button>
        <Label Name="IncorrectData"
               Text="{Loc 'test-blabalba'}"
               Align="Center"
               FontColorOverride="Red"
               Visible="False"/>
        <BoxContainer MinHeight="20"></BoxContainer>
    </BoxContainer>
</DefaultWindow>
